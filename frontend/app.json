{
  "expo": {
    "name": "AI Quiz App",
    "slug": "ai-quiz-app",
    "version": "1.0.0",
    "scheme": "ai-quiz-app",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aiquizapp.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AI Quiz App needs microphone access to record your spoken answers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0B0F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aiquizapp.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "AI Quiz App needs microphone access to record your spoken answers."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7fdbf5c2-dbdf-44c5-b086-b234a1389415"
      }
    }
  }
}
